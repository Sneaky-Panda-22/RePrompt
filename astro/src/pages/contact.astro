---
import InfoLayout from "../layouts/InfoLayout.astro";
---

<InfoLayout 
  title="Contact Us" 
  description="Contact the RePrompt team for questions, feedback, API integrations, and support." 
  activePath="/contact"
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-border/80 pb-6 text-center md:text-left">
      <span class="text-xs uppercase tracking-widest text-muted-foreground font-mono-custom">Get In Touch</span>
      <h1 class="text-4xl md:text-5xl font-serif italic font-bold mt-2">Contact Us</h1>
      <p class="text-muted-foreground mt-2">Have questions about RePrompt? We'd love to hear from you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Contact Info Cards -->
      <div class="md:col-span-1 space-y-6">
        <div class="p-6 bg-card border border-border/60 rounded-2xl">
          <h3 class="font-bold text-sm tracking-wider uppercase font-mono-custom text-muted-foreground mb-2">GitHub</h3>
          <div class="space-y-2">
            <p class="text-foreground font-medium hover:text-accent transition-colors">
              <a href="https://github.com/Sneaky-Panda-22" target="_blank" rel="noopener noreferrer">@Sneaky-Panda-22</a>
            </p>
            <p class="text-foreground font-medium hover:text-accent transition-colors">
              <a href="https://github.com/kshitijpunani" target="_blank" rel="noopener noreferrer">@kshitijpunani</a>
            </p>
          </div>
          <span class="text-xs text-muted-foreground block mt-3">Submit issues & PRs</span>
        </div>

        <div class="p-6 bg-card border border-border/60 rounded-2xl">
          <h3 class="font-bold text-sm tracking-wider uppercase font-mono-custom text-muted-foreground mb-2">Email Support</h3>
          <p class="text-foreground font-medium hover:text-accent transition-colors">
            <a href="mailto:support@reprompt.app">support@reprompt.app</a>
          </p>
          <span class="text-xs text-muted-foreground block mt-1">Typical response within 24h</span>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-2 p-8 bg-card border border-border/60 rounded-3xl">
        <h2 class="text-xl font-serif italic font-bold mb-6">Send a Message</h2>
        <form id="contact-form" class="space-y-4" onsubmit="event.preventDefault(); alert('Message sent! Thank you for reaching out.'); this.reset();">
          <div>
            <label for="name" class="block text-xs uppercase tracking-wider font-mono-custom text-muted-foreground mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              required 
              class="w-full px-4 py-3 bg-secondary/30 border border-border rounded-xl focus:outline-none focus:border-accent text-foreground text-sm transition-colors"
              placeholder="Your Name"
            />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-wider font-mono-custom text-muted-foreground mb-2">Email Address</label>
            <input 
              type="email" 
              id="email" 
              required 
              class="w-full px-4 py-3 bg-secondary/30 border border-border rounded-xl focus:outline-none focus:border-accent text-foreground text-sm transition-colors"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="message" class="block text-xs uppercase tracking-wider font-mono-custom text-muted-foreground mb-2">Message</label>
            <textarea 
              id="message" 
              required 
              rows="5"
              class="w-full px-4 py-3 bg-secondary/30 border border-border rounded-xl focus:outline-none focus:border-accent text-foreground text-sm transition-colors resize-none"
              placeholder="Tell us what you're working on..."
            ></textarea>
          </div>
          <button 
            type="submit" 
            class="w-full py-3 bg-foreground text-background font-medium hover:bg-foreground/90 transition-colors rounded-xl text-sm font-mono-custom cursor-pointer"
          >
            Send Message &rarr;
          </button>
        </form>
      </div>

    </div>
  </div>
</InfoLayout>
