const sections = [
  { id: "about", num: "01", title: "Reverse Engineering the Visual",
    gradient: "linear-gradient(180deg, #1b1e3a 0%, #4a3956 28%, #6b5b8a 60%, #8888bb 100%)",
    fig: "polygon",
    content: "RePrompt is a free image to prompt generator that extracts the exact prompt from any AI-generated image. Upload your image and our AI analyzes camera settings, lighting, color palettes, composition, and materials to reconstruct the complete prompt — supporting Midjourney, DALL-E, and Stable Diffusion." },
  { id: "faq", num: "02", title: "AI Prompt Forensics",
    gradient: "linear-gradient(180deg, #1a2a3a 0%, #2a4a6a 35%, #5b8cb6 65%, #92aebd 100%)",
    fig: "circle",
    content: "Our image to prompt AI engine performs deep forensic analysis across seven dimensions: camera and lens, lighting setup, color harmony, composition, materials, atmosphere, and post-processing. Each image to prompt extraction is detailed and accurate, giving you a complete breakdown of how the image was created." },
  { id: "privacy", num: "03", title: "Client-Side Processing",
    gradient: "linear-gradient(180deg, #1a2a28 0%, #2a4a48 35%, #4a7a76 65%, #7aaaa6 100%)",
    fig: "shield",
    content: "Every image to prompt analysis runs entirely in your browser — no images are uploaded to any server. This makes our free image to prompt generator the most private and secure option available. Your images stay on your device, and we never have access to them. Complete privacy, guaranteed." },
  { id: "terms", num: "04", title: "Supported Platforms",
    gradient: "linear-gradient(180deg, #2a2a1a 0%, #4a4a2a 35%, #7a7a4a 65%, #aaaa6a 100%)",
    fig: "lines",
    content: "RePrompt works with all major AI image generators including Midjourney, DALL-E 3, Stable Diffusion, Adobe Firefly, and more. Our ai image to prompt tool is platform-agnostic — upload any AI-generated image and get a detailed prompt reconstruction regardless of which tool created it." },
  { id: "contact", num: "05", title: "100% Free, No Limits",
    gradient: "linear-gradient(180deg, #1a2a1a 0%, #2a4a2a 35%, #4a7a4a 65%, #6aaa7a 100%)",
    fig: "diamond",
    content: "RePrompt is a completely free image to prompt generator with no sign-ups, no usage limits, and no hidden fees. Extract unlimited prompts from unlimited images. Our image to prompt online tool is free forever — no account required, no credit card needed, just upload and discover the prompt." }
];
