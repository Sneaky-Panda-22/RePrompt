  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --stage: #0a0a0a;
      --paper: #f4ede0;
      --serif: 'Instrument Serif', 'Iowan Old Style', Georgia, serif;
      --mono: 'IBM Plex Mono', ui-monospace, monospace;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      background:
        radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,255,255,0.04), transparent 70%),
        #0a0a0a;
      color: var(--paper);
      font: 14px/1.6 -apple-system, system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }

    .stage {
      max-width: 1280px;
      margin: 0 auto;
      padding: 48px 32px 80px;
    }

    /* ── Nav ── */
    .page-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 80px;
    }
    .nav-links-header {
      display: flex;
      gap: 24px;
    }
    .header-nav-link {
      font: 11px/1 var(--mono);
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: rgba(244,237,224,0.45);
      transition: color 0.25s ease;
    }
    .header-nav-link:hover {
      color: var(--paper);
    }
    .page-head .launch-link {
      font: 11px/1 var(--mono);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 8px 16px;
      border: 1px solid rgba(244,237,224,0.25);
      border-radius: 999px;
      color: rgba(244,237,224,0.7);
      transition: all 0.3s ease;
    }
    .page-head .launch-link:hover {
      border-color: var(--paper);
      color: var(--paper);
      background: rgba(244,237,224,0.06);
    }
    
    .page-head .logo-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: auto;
    }
    .launch-link.mobile-only {
      display: none;
    }
    .launch-link.desktop-only {
      display: inline-block;
    }

    @media (max-width: 640px) {
      .page-head {
        flex-direction: column;
        gap: 20px;
        align-items: center;
      }
      .page-head .logo-container {
        width: 100%;
      }
      .launch-link.mobile-only {
        display: inline-block;
      }
      .launch-link.desktop-only {
        display: none;
      }
      .nav-links-header {
        justify-content: center;
        flex-wrap: wrap;
        gap: 16px;
      }
      .header-nav-link {
        font-size: 10px;
      }
    }
    .wordmark {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .wordmark .logo-mark {
      width: 28px; height: 28px;
      border: 1.5px solid var(--paper);
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font: italic 700 13px/1 var(--serif);
      color: var(--paper);
      opacity: 0.8;
    }
    .wordmark .name {
      font: italic 700 18px/1 var(--serif);
      color: var(--paper);
      letter-spacing: -0.01em;
    }
    .wordmark .name .dot { color: #a4a09a; }
    .page-head .launch-link {
      font: 11px/1 var(--mono);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 8px 16px;
      border: 1px solid rgba(244,237,224,0.25);
      border-radius: 999px;
      color: rgba(244,237,224,0.7);
      transition: all 0.3s ease;
    }
    .page-head .launch-link:hover {
      border-color: var(--paper);
      color: var(--paper);
      background: rgba(244,237,224,0.06);
    }

    /* ── Hero ── */
    .hero {
      max-width: 780px;
      margin-bottom: 80px;
    }
    .hero h1 {
      font: italic 700 56px/1 var(--serif);
      letter-spacing: -0.01em;
      color: #ffffff;
      margin-bottom: 16px;
    }
    .hero h1 em { font-style: italic; }
    .hero h1 .dot { color: #a4a09a; }
    .hero .sub {
      font: 12px/1.7 var(--mono);
      color: rgba(244,237,224,0.5);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      max-width: 72ch;
      margin-bottom: 32px;
    }
    .hero .cta-row {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
    }
    .hero .cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font: italic 700 18px/1 var(--serif);
      padding: 12px 28px;
      background: #ffffff;
      color: #0a0a0a;
      border-radius: 999px;
      transition: all 0.25s ease;
    }
    .hero .cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.4);
    }
    .hero .cta-hint {
      font: 10.5px/1 var(--mono);
      color: rgba(244,237,224,0.35);
      letter-spacing: 0.12em;
    }

    /* ── Label ── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 36px;
    }
    .section-label span {
      font: 10px/1 var(--mono);
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(244,237,224,0.3);
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(244,237,224,0.08);
    }

    /* ── Cards ── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 24px;
      max-width: 1116px;
      margin: 0 auto;
    }
    .card {
      grid-column: span 2;
    }
    .card:nth-child(4),
    .card:nth-child(5) {
      grid-column: span 3;
    }
    @media (max-width: 1100px) {
      .card-grid {
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        max-width: none;
      }
      .card, .card:nth-child(4), .card:nth-child(5) {
        grid-column: span 1;
      }
    }

    .card {
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 30px 60px rgba(0,0,0,0.45);
      position: relative;
      overflow: hidden;
      color: #fff;
      cursor: default;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 40px 80px rgba(0,0,0,0.55);
    }
    .card .scrim {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.40) 50%, rgba(0,0,0,0.65) 100%);
      pointer-events: none;
      z-index: 1;
    }
    .card .texture {
      position: absolute; inset: 0;
      opacity: 0.06;
      background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.03) 2px, rgba(255,255,255,0.03) 4px);
      pointer-events: none;
      z-index: 0;
    }

    /* Figures */
    .card .fig {
      position: absolute;
      pointer-events: none;
      z-index: 0;
    }
    .card .fig-polygon {
      right: -30px; bottom: -20px;
      width: 200px; height: 200px;
      background: rgba(255,255,255,0.05);
      clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
    }
    .card .fig-circle {
      right: -40px; top: -40px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
    }
    .card .fig-shield {
      left: -20px; bottom: -20px;
      width: 160px; height: 180px;
      background: rgba(255,255,255,0.05);
      clip-path: polygon(50% 0%, 80% 10%, 100% 35%, 100% 70%, 50% 100%, 0% 70%, 0% 35%, 20% 10%);
    }
    .card .fig-lines {
      right: -10px; top: 20%;
      width: 120px; height: 120px;
      background: rgba(255,255,255,0.05);
      clip-path: polygon(0% 15%, 100% 15%, 100% 25%, 0% 25%, 0% 40%, 100% 40%, 100% 50%, 0% 50%, 0% 65%, 100% 65%, 100% 75%, 0% 75%, 0% 90%, 100% 90%, 100% 100%, 0% 100%);
    }
    .card .fig-diamond {
      left: 10%; top: -40px;
      width: 180px; height: 180px;
      background: rgba(255,255,255,0.05);
      clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
      transform: rotate(30deg);
    }

    /* Card layout */
    .card .top {
      position: relative; z-index: 2;
      display: flex; justify-content: space-between; align-items: flex-start;
      padding: 20px 22px 0;
    }
    .card .brand {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 10px;
      background: rgba(255,255,255,0.10);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border-radius: 999px;
    }
    .card .brand .dot {
      width: 5px; height: 5px;
      background: var(--paper);
      border-radius: 50%;
      opacity: 0.9;
    }
    .card .brand .name {
      font: italic 700 13px/1 var(--serif);
      color: #fff;
    }
    .card .index {
      font: 10.5px/1.4 var(--mono);
      color: rgba(255,255,255,0.75);
      letter-spacing: 0.16em;
      padding: 6px 10px;
      background: rgba(0,0,0,0.30);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      border-radius: 4px;
    }

    .card .lockup {
      position: relative; z-index: 2;
      padding: 60px 22px 0;
    }
    .card .lockup h2 {
      font: 700 48px/1 var(--serif);
      letter-spacing: -0.01em;
      color: #fff;
    }
    .card .lockup h2 em { font-style: italic; }

    .card .body {
      position: relative; z-index: 2;
      padding: 16px 22px 80px;
      font: 14px/1.75 -apple-system, system-ui, sans-serif;
      color: rgba(255,255,255,0.88);
      max-width: 92%;
    }

    .card .footer {
      position: absolute; z-index: 2;
      left: 22px; right: 22px;
      bottom: 18px;
      display: flex; justify-content: space-between; align-items: center;
    }
    .card .footer .caption {
      font: 10.5px/1.4 var(--mono);
      color: rgba(255,255,255,0.80);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      max-width: 70%;
    }

    /* ── Footer ── */
    .page-foot {
      margin-top: 80px;
      border-top: 1px solid rgba(244,237,224,0.06);
      padding-top: 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .page-foot .copy {
      font: 10.5px/1.4 var(--mono);
      color: rgba(244,237,224,0.25);
      letter-spacing: 0.08em;
    }
    .page-foot .nav-links {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .page-foot .nav-links a {
      font: 10.5px/1 var(--mono);
      color: rgba(244,237,224,0.3);
      letter-spacing: 0.10em;
      text-transform: uppercase;
      transition: color 0.2s ease;
    }
    .page-foot .nav-links a:hover { color: var(--paper); }

    /* ── SEO content ── */
    .seo-content {
      max-width: 840px;
      margin: 100px auto 80px;
      padding: 0 16px;
    }
    .seo-content h2 {
      font: italic 700 42px/1.2 var(--serif);
      color: #ffffff;
      letter-spacing: -0.02em;
      margin-bottom: 32px;
      text-align: center;
    }
    .seo-content > p:first-child {
      text-align: center;
      margin-bottom: 32px;
      font-size: 16px;
    }
    .seo-content p {
      font: 16px/1.9 -apple-system, system-ui, sans-serif;
      color: rgba(244,237,224,0.75);
      margin-bottom: 20px;
      text-align: left;
    }
    .seo-content h3 {
      font: 600 22px/1.3 -apple-system, system-ui, sans-serif;
      color: rgba(244,237,224,0.95);
      margin-top: 48px;
      margin-bottom: 18px;
      letter-spacing: -0.01em;
      text-align: left;
    }
    .seo-content ul {
      padding: 0;
      margin-bottom: 28px;
    }
    .seo-content ul li {
      font: 15px/1.8 -apple-system, system-ui, sans-serif;
      color: rgba(244,237,224,0.75);
      padding-left: 24px;
      margin-bottom: 12px;
      position: relative;
    }
    .seo-content ul li::before {
      content: "▸";
      position: absolute;
      left: 0;
      color: rgba(244,237,224,0.4);
      font-weight: 600;
    }
    .seo-content > p:last-child {
      text-align: center;
      margin-top: 40px;
      padding-top: 24px;
      border-top: 1px solid rgba(244,237,224,0.1);
      font-size: 16px;
    }

    /* ── FAQ Section ── */
    .faq-section {
      margin-top: 100px;
      padding-bottom: 80px;
    }
    .faq-container {
      max-width: 740px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .faq-title {
      font: italic 700 42px/1.2 var(--serif);
      color: #ffffff;
      text-align: center;
      margin-bottom: 12px;
    }
    .faq-subtitle {
      font: 13px/1.6 var(--mono);
      color: rgba(244,237,224,0.35);
      text-align: center;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 48px;
    }
    .faq-item {
      margin-bottom: 12px;
      border: 1px solid rgba(244,237,224,0.08);
