---
export interface Props {
  currentPath: string;
  title?: string;
  eyebrow?: string;
}

const { currentPath, title = "Forensic App", eyebrow = "01 \u2014 Prompt Extraction" } = Astro.props;

const NAV_ITEMS = [
  { href: "/app", label: "Forensic App", idx: "01", icon: "terminal" },
  { href: "/similarity", label: "Similarity Lab", idx: "02", icon: "refresh" },
  { href: "/batch", label: "Batch Mode", idx: "03", icon: "layers" },
  { href: "/practice", label: "Practice Mode", idx: "04", icon: "pencil" },
  { href: "/daily", label: "Daily Challenge", idx: "05", icon: "calendar" },
];

const sectionTitle: Record<string, string> = {
  "/app": "Forensics App",
  "/similarity": "Similarity Lab",
  "/batch": "Batch Mode",
  "/practice": "Practice Sandbox",
  "/daily": "Daily Challenge",
};

const sectionEyebrow: Record<string, string> = {
  "/app": "01 \u2014 Prompt Extraction",
  "/similarity": "02 \u2014 Target Alignment",
  "/batch": "03 \u2014 Multi-Asset Sweep",
  "/practice": "04 \u2014 Workshop",
  "/daily": "05 \u2014 Daily Brief",
};

const pageTitle = sectionTitle[currentPath] ?? title;
const pageEyebrow = sectionEyebrow[currentPath] ?? eyebrow;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Image to Prompt — {pageTitle} | RePrompt</title>
    <meta name="description" content="Free image to prompt generator — upload any AI image and get the exact prompt used. RePrompt is the most advanced image to prompt AI tool for forensic prompt analysis." />
    <meta name="keywords" content="image to prompt, image to prompt generator, image to prompt generator free, image to prompt ai, ai image to prompt, free image to prompt generator, prompt extraction, reverse engineer prompt" />
    <meta name="author" content="Parth Tandon" />
    <link rel="canonical" href="https://reprompt.app/app" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RePrompt" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content="Image to Prompt — {pageTitle} | RePrompt" />
    <meta property="og:description" content="Free image to prompt generator — upload any AI image and get the exact prompt used. Reverse-engineer Midjourney, DALL-E & Stable Diffusion prompts instantly." />
    <meta property="og:url" content="https://reprompt.app/app" />
    <meta property="og:image" content="https://reprompt.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Image to Prompt — {pageTitle} | RePrompt" />
    <meta name="twitter:description" content="Free image to prompt generator — upload any AI image and get the exact prompt used. No sign-up, no uploads, completely free." />
    <meta name="twitter:image" content="https://reprompt.app/og-image.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <!-- Inline theme script — prevents flash -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        var prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefers)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-background text-foreground antialiased font-sans">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-primary-foreground px-4 py-2 rounded-lg z-50">Skip to Content</a>

    <div class="flex h-dvh w-screen overflow-hidden bg-background">
      <!-- Mobile backdrop -->
      <div id="mobile-backdrop" class="fixed inset-0 z-40 md:hidden bg-black/40 dark:bg-black/60 backdrop-blur-sm hidden transition-opacity duration-300" onclick="toggleMobile()"></div>

      <!-- ===== SIDEBAR ===== -->
      <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-72 md:static flex flex-col h-dvh border-r border-border bg-card/70 backdrop-blur-xl flex-shrink-0 -translate-x-full md:translate-x-0 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
        <!-- Brand -->
        <div class="h-20 flex items-center gap-3 px-6 relative">
          <a href="/" class="flex items-center gap-3 no-underline">
            <span class="flex items-center justify-center w-[30px] h-[30px] rounded-md border border-foreground/30 text-foreground/80" style="font: italic 700 14px/1 'Instrument Serif', 'Iowan Old Style', Georgia, serif">R</span>
            <span class="text-foreground/90" style="font: italic 700 19px/1 'Instrument Serif', 'Iowan Old Style', Georgia, serif; letter-spacing: -0.01em">RePrompt<span style="color: #a4a09a;">.</span></span>
          </a>
          <!-- Mobile close -->
          <button onclick="toggleMobile()" class="md:hidden h-9 w-9 inline-flex items-center justify-center rounded-lg text-muted-foreground hover:bg-secondary hover:text-foreground border border-border transition-colors absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer" aria-label="Close navigation">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <div class="h-px bg-gradient-to-r from-transparent via-border to-transparent mx-4" />

        <div class="px-6 pt-6 pb-3">
          <span class="label-mono text-muted-foreground/60">Workspace</span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-3 pb-2 space-y-0.5 overflow-y-auto">
          <!-- Home link -->
          <a
            href="/"
            class="group/nav relative w-full flex items-center gap-3 pl-3 pr-3.5 h-11 rounded-lg text-sm font-medium transition-premium cursor-pointer overflow-hidden text-muted-foreground hover:text-foreground"
          >
            <span aria-hidden="true" class="absolute left-0 top-2 bottom-2 w-[2px] rounded-full transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] bg-foreground opacity-0 scale-y-50 group-hover/nav:opacity-30 group-hover/nav:scale-y-75" />
            <span aria-hidden="true" class="absolute inset-0 transition-opacity duration-300 rounded-lg opacity-0 group-hover/nav:opacity-60 group-hover/nav:bg-secondary/60" />
            <span class="relative w-7 text-center font-mono text-[10px] tracking-widest transition-colors duration-300 text-muted-foreground/45 group-hover/nav:text-muted-foreground">
              <svg class="w-3.5 h-3.5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 0 1 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
              </svg>
            </span>
            <span class="relative w-4 h-4 flex-shrink-0"></span>
            <span class="relative truncate">Home</span>
          </a>

          <div class="h-px bg-gradient-to-r from-transparent via-border/40 to-transparent mx-2 my-2" />

          {NAV_ITEMS.map((item) => {
            const isActive = currentPath === item.href;
            return (
              <a
                href={item.href}
                class={`group/nav relative w-full flex items-center gap-3 pl-3 pr-3.5 h-11 rounded-lg text-sm font-medium transition-premium cursor-pointer overflow-hidden ${
                  isActive
                    ? "text-foreground"
                    : "text-muted-foreground hover:text-foreground"
                }`}
                aria-current={isActive ? "page" : undefined}
              >
                <span aria-hidden="true" class={`absolute left-0 top-2 bottom-2 w-[2px] rounded-full transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] ${
                  isActive
                    ? "bg-foreground opacity-100 scale-y-100"
                    : "bg-foreground opacity-0 scale-y-50 group-hover/nav:opacity-30 group-hover/nav:scale-y-75"
                }`} />
                <span aria-hidden="true" class={`absolute inset-0 transition-opacity duration-300 rounded-lg ${
                  isActive
                    ? "bg-secondary opacity-90"
                    : "opacity-0 group-hover/nav:opacity-60 group-hover/nav:bg-secondary/60"
                }`} />
                <span class={`relative w-7 text-center font-mono text-[10px] tracking-widest transition-colors duration-300 ${
                  isActive ? "text-foreground font-semibold" : "text-muted-foreground/45 group-hover/nav:text-muted-foreground"
                }`}>{item.idx}</span>

                <!-- Icon -->
                <span class="relative w-4 h-4 flex-shrink-0">
                  {item.icon === "terminal" && (
                    <svg class={`w-4 h-4 transition-all duration-300 ${isActive ? "text-foreground" : "text-muted-foreground group-hover/nav:text-foreground"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width={isActive ? 2.2 : 1.8}>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16M8 12h8"/>
                    </svg>
                  )}
                  {item.icon === "refresh" && (
                    <svg class={`w-4 h-4 transition-all duration-300 ${isActive ? "text-foreground" : "text-muted-foreground group-hover/nav:text-foreground"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width={isActive ? 2.2 : 1.8}>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/>
                    </svg>
                  )}
                  {item.icon === "layers" && (
                    <svg class={`w-4 h-4 transition-all duration-300 ${isActive ? "text-foreground" : "text-muted-foreground group-hover/nav:text-foreground"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width={isActive ? 2.2 : 1.8}>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3"/>
                    </svg>
                  )}
                  {item.icon === "pencil" && (
                    <svg class={`w-4 h-4 transition-all duration-300 ${isActive ? "text-foreground" : "text-muted-foreground group-hover/nav:text-foreground"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width={isActive ? 2.2 : 1.8}>
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>
                    </svg>
                  )}
                  {item.icon === "calendar" && (
                    <svg class={`w-4 h-4 transition-all duration-300 ${isActive ? "text-foreground" : "text-muted-foreground group-hover/nav:text-foreground"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width={isActive ? 2.2 : 1.8}>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
                    </svg>
                  )}
                </span>

                <span class="relative truncate">{item.label}</span>

                {isActive && (
                  <span aria-hidden="true" class="relative ml-auto inline-flex w-1.5 h-1.5 rounded-full bg-foreground/40" />
                )}
              </a>
            );
          })}
        </nav>

        <!-- Sidebar footer -->
        <div class="border-t border-border">
          <div class="p-5 pb-safe space-y-3">
            <!-- Theme toggle -->
            <button onclick="toggleTheme()" role="switch" aria-checked="false" id="theme-toggle" class="group relative w-full h-10 rounded-xl flex items-center justify-between gap-2 px-1 border border-border bg-secondary/60 hover:bg-secondary transition-all duration-300 cursor-pointer select-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background">
              <span id="theme-slider" class="absolute top-1 bottom-1 left-1 right-[calc(50%-2px)] rounded-lg bg-card shadow-sm border border-border transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]" />
              <span id="theme-label-light" class="relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-foreground transition-all duration-300">
                <svg class="w-3.5 h-3.5 text-accent transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
                </svg>
                Light
              </span>
              <span id="theme-label-dark" class="relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-muted-foreground transition-all duration-300">
                Dark
                <svg class="w-3.5 h-3.5 transition-all duration-300 -rotate-90 scale-75 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
                </svg>
              </span>
            </button>

            <!-- Status -->
            <div class="flex items-center justify-between gap-2 px-1">
              <span class="label-mono text-muted-foreground/50 truncate">API &middot; Online</span>
              <span class="relative inline-flex items-center justify-center w-2 h-2">
                <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-60 animate-ping" />
                <span class="relative inline-flex w-2 h-2 rounded-full bg-emerald-500" />
              </span>
            </div>
          </div>
        </div>
      </aside>

      <!-- ===== MAIN WORKSPACE ===== -->
      <main id="main-content" class="flex-1 flex flex-col h-full overflow-hidden">
        <!-- Header -->
        <header class="relative h-20 flex items-center justify-between px-5 md:px-10 z-10 flex-shrink-0">
          <div class="flex items-center gap-4 min-w-0">
            <button onclick="toggleMobile()" aria-label="Open navigation" class="md:hidden h-10 w-10 inline-flex items-center justify-center rounded-xl text-muted-foreground hover:bg-secondary hover:text-foreground border border-border transition-colors cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <div class="absolute left-1/2 -translate-x-1/2 md:static md:translate-x-0 flex items-baseline gap-3 min-w-0 pointer-events-none md:pointer-events-auto text-center md:text-left">
              <span class="label-mono text-muted-foreground whitespace-nowrap hidden sm:inline">{pageEyebrow}</span>
              <span class="hidden sm:inline-block w-px h-3 bg-border" />
              <h1 class="font-sans text-xl sm:text-[1.55rem] md:text-2xl leading-none font-semibold tracking-tight text-foreground truncate">{pageTitle}</h1>
            </div>
          </div>
          <div class="flex items-center gap-2 md:gap-3 flex-shrink-0">
            <div class="hidden md:flex items-center gap-2 px-3 h-8 rounded-full bg-card/70 border border-border">
              <span class="relative w-1.5 h-1.5 rounded-full bg-emerald-500">
                <span class="absolute inset-0 rounded-full bg-emerald-500/60 animate-ping" />
              </span>
              <span class="label-mono text-muted-foreground">API &middot; Online</span>
            </div>
            <div class="flex md:hidden items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500" />
            </div>
          </div>
        </header>

        <!-- Hairline -->
        <div class="h-px bg-gradient-to-r from-transparent via-border to-transparent mx-5 md:mx-10" />

        <!-- Page content -->
        <div class="flex-1 overflow-y-auto px-5 md:px-10 py-8 md:py-10">
          <div class="max-w-6xl mx-auto h-full">
            <slot />
          </div>
        </div>
      </main>
    </div>

    <!-- Error diagnostics -->
    <div id="diag-errors" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:#111;color:#f44;padding:40px;overflow:auto;font-family:monospace;font-size:14px;white-space:pre-wrap"></div>
    <script is:inline>
      (function(){
        var div = document.getElementById('diag-errors');
        function show(e) {
          div.style.display = 'block';
          div.textContent += '[' + new Date().toISOString() + '] ' + (e && e.message ? e.message + '\n' + (e.stack || '') : String(e)) + '\n\n';
        }
        window.addEventListener('error', function(e) { show(e.error || e); });
        window.addEventListener('unhandledrejection', function(e) { show(e.reason); });
        var origSetTimeout = window.setTimeout;
        window.setTimeout = function(fn, ms) {
          return origSetTimeout(function() {
            try { if (typeof fn === 'function') fn(); else fn[0](); } catch(e) { show(e); }
          }, ms);
        };
        // Also intercept dynamic imports
        var origFetch = window.fetch;
        window.fetch = function() { return origFetch.apply(this, arguments).catch(function(e) { show(e); throw e; }); };
        console.error = function() {
          for (var i = 0; i < arguments.length; i++) show(arguments[i]);
        };
      })();
    </script>

    <!-- Inline scripts -->
    <script is:inline>
      function toggleMobile() {
        var sidebar = document.getElementById('sidebar');
        var backdrop = document.getElementById('mobile-backdrop');
        sidebar.classList.toggle('-translate-x-full');
        backdrop.classList.toggle('hidden');
      }

      function toggleTheme() {
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        var newTheme = isDark ? 'light' : 'dark';
        var slider = document.getElementById('theme-slider');
        var lightLabel = document.getElementById('theme-label-light');
        var darkLabel = document.getElementById('theme-label-dark');

        html.classList.toggle('dark');
        localStorage.setItem('theme', newTheme);

        if (newTheme === 'dark') {
          slider.className = 'absolute top-1 bottom-1 left-[calc(50%-2px)] right-1 rounded-lg bg-card shadow-sm border border-border transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]';
          lightLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-muted-foreground transition-all duration-300';
          darkLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-foreground transition-all duration-300';
        } else {
          slider.className = 'absolute top-1 bottom-1 left-1 right-[calc(50%-2px)] rounded-lg bg-card shadow-sm border border-border transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]';
          lightLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-foreground transition-all duration-300';
          darkLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-muted-foreground transition-all duration-300';
        }
      }

      // Sync theme toggle state on load
      document.addEventListener('DOMContentLoaded', function() {
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        var slider = document.getElementById('theme-slider');
        var lightLabel = document.getElementById('theme-label-light');
        var darkLabel = document.getElementById('theme-label-dark');

        if (isDark) {
          slider.className = 'absolute top-1 bottom-1 left-[calc(50%-2px)] right-1 rounded-lg bg-card shadow-sm border border-border transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)]';
          if (lightLabel) lightLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-muted-foreground transition-all duration-300';
          if (darkLabel) darkLabel.className = 'relative z-10 flex-1 flex items-center justify-center gap-1.5 text-[11px] font-semibold tracking-wide font-mono text-foreground transition-all duration-300';
        }
      });
    </script>
  </body>
</html>
